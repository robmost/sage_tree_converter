# LLM API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# External Data Mounts (Optional)
# Specify absolute paths to your external data directories.
# If left commented or blank, defaults to the local ./input and ./output directories
# INPUT_DIR=/path/to/your/external/input
# OUTPUT_DIR=/path/to/your/external/output

# Tuning Parameters
# The multiplier used to estimate peak memory usage from input file size. Default is 3.0.
# SAGE_MEMORY_MULTIPLIER=3.0
