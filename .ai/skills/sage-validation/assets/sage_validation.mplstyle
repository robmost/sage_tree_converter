# Set default figure size
figure.figsize : 6, 6
figure.dpi : 140

# Set x axis
xtick.major.size : 7.5
xtick.major.width : 2
xtick.minor.size : 5.5
xtick.minor.width : 1
xtick.direction : in
xtick.top : True

# Set y axis
ytick.major.size : 7.5
ytick.major.width : 2
ytick.minor.size : 5.5
ytick.minor.width : 1
ytick.direction : in
ytick.right : True

# Fontsizes
xtick.labelsize : 10
ytick.labelsize : 10
xtick.major.pad : 9
legend.fontsize : 8
legend.title_fontsize : 12
axes.titlesize : 12
axes.labelsize : 10

# Line widths
axes.linewidth : 2.5
grid.linewidth : 1
lines.linewidth : 2
lines.solid_capstyle : round

# Font style
font.family : sans-serif
text.usetex : False
font.size:    20.0
font.sans-serif: DejaVu Sans, Helvetica, Arial, sans-serif

# margins
#axes.xmargin : 0
#axes.ymargin : 0

# Legend
legend.frameon : False

# Set color cycle:
# blue, orange, green, red, purple, black, grey
axes.prop_cycle : cycler('color', ['0C5DA5', '00B945', 'FF9500', 'FF2C00', '845B97', '474747', '9e9e9e'])
